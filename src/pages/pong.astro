  "🃏 JOLLY: inventa tu una sfida per qualcuno, il gruppo decide se è abbastanza folle",
  "⚡ SPEED ROUND: tutti bevono ogni volta che qualcuno dice 'sì' per 1 minuto",
  "🌀 CAOS TOTALE: tutti si alzano, cambiano posto e il giro riparte da capo",
  "🎤 KARAOKE FORZATO: tutti cantano insieme per 20 secondi la stessa canzone",
  "📸 SELFIE DI GRUPPO: tutti nella foto entro 10 secondi o si beve!",
  "🃏 VERITÀ O BEVI: scegli qualcuno, fai una domanda scomoda — risponde o beve 3 sorsi",
  "🏆 CAMPIONE: il giocatore alla tua sinistra è immune per i prossimi 2 turni",
  "🔥 CATENA: ognuno beve un sorso a turno finché qualcuno si rifiuta — quel giocatore beve 4",
  "🎲 DADO UMANO: tutti gridano un numero 1-6, chi indovina il totale assegna 3 sorsi",
];

// ── ULTRA RARI (~2% probabilità) ──────────────────────────────────────────
const eventiUltraRari = [
  "☢️ NUCLEARE: TUTTI finiscono il bicchiere — nessuno escluso",
  "👑 DITTATORE: inventi una regola valida fino alla fine della partita",
  "🧊 FREEZE: puoi congelare qualsiasi giocatore per un intero turno",
  "🎯 HEADSHOT: scegli qualcuno che deve finire il bicchiere adesso",
  "🃏 GOD MODE: sei immune a tutte le penalità per i prossimi 3 turni",
  "💸 BANCAROTTA: il giocatore con più sorsi bevuti questa sera assegna 5 sorsi a chi vuole",
  "🌋 ERUZIONE: tutti bevono 2 sorsi ogni turno per i prossimi 3 turni",
  "🎪 CIRCO: il gruppo vota la sfida più assurda mai vista — chi la esegue è esonerato per 2 turni",
];

// ── LOGICA ────────────────────────────────────────────────────────────────
const tutteCategorie = Object.keys(eventi);

let contatore = 0;
let inCorso = false;

function randomItem(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

function setCard(categoria, testo, animate) {
  const card     = document.getElementById("card");
  const badge    = document.getElementById("badgeCategoria");
  const eventoEl = document.getElementById("eventoText");
  const s        = categoriaStyles[categoria];

  card.style.borderColor = s.border;
  card.style.background  = s.bg;
  badge.style.color       = s.badgeColor;
  badge.style.background  = s.badgeBg;
  badge.style.borderColor = s.badgeColor;
  badge.style.opacity     = "1";
  badge.style.transform   = "translateY(0)";
  badge.textContent       = labelCategoria[categoria];
  eventoEl.textContent    = testo;

  const isSpecial = categoria === "raro" || categoria === "ultrararo";

  if (animate) {
    card.style.animation = "";
    void card.offsetWidth;
    card.style.animation = isSpecial
      ? "pop 0.35s cubic-bezier(.22,1,.36,1) forwards, rarePulse 1.8s ease-in-out 0.35s infinite"
      : "pop 0.35s cubic-bezier(.22,1,.36,1) forwards";
  } else {
    card.style.animation = isSpecial ? "rarePulse 1.8s ease-in-out infinite" : "";
  }

  if (isSpecial) spawnConfetti();
}

async function slotAnimation() {
  const card     = document.getElementById("card");
  const eventoEl = document.getElementById("eventoText");
  const badge    = document.getElementById("badgeCategoria");
  const FRAMES   = 14;

  card.style.animation = "shakeCard 0.4s ease forwards";

  for (let i = 0; i < FRAMES; i++) {
    const c = randomItem(tutteCategorie);
    const e = randomItem(eventi[c]);
    const s = categoriaStyles[c];

    card.style.borderColor  = s.border;
    card.style.background   = s.bg;
    badge.style.color       = s.badgeColor;
    badge.style.background  = s.badgeBg;
    badge.style.borderColor = s.badgeColor;
    badge.style.opacity     = "1";
    badge.style.transform   = "translateY(0)";
    badge.textContent       = labelCategoria[c];
    eventoEl.textContent    = e;

    await new Promise(r => setTimeout(r, 50 + i * 10));
  }
}

async function genera() {
  if (inCorso) return;
  inCorso = true;

  const btn = document.getElementById("btnSfida");
  btn.disabled = true;

  await slotAnimation();

  let categoria, testo;
  const r = Math.random();

  if (r < 0.02) {
    // 2% ultra raro
    categoria = "ultrararo";
    testo     = randomItem(eventiUltraRari);
  } else if (r < 0.10) {
    // 8% raro
    categoria = "raro";
    testo     = randomItem(eventiRari);
  } else {
    categoria = randomItem(tutteCategorie);
    testo     = randomItem(eventi[categoria]);
  }

  setCard(categoria, testo, true);

  contatore++;
  document.getElementById("countBadge").textContent = `Sfida #${contatore}`;

  btn.disabled = false;
  inCorso = false;
}

function spawnConfetti() {
  const overlay = document.getElementById("raroOverlay");
  overlay.style.display = "block";
  overlay.innerHTML = "";
  const colors = ["#a855f7","#fbbf24","#22c55e","#ef4444","#3b82f6","#f0eee8","#ec4899","#06b6d4"];
  for (let i = 0; i < 55; i++) {
    const el = document.createElement("div");
    el.className = "confetti-piece";
    el.style.left = Math.random() * 100 + "vw";
    el.style.top  = "-20px";
    el.style.background = randomItem(colors);
    el.style.animationDelay    = Math.random() * 0.8 + "s";
    el.style.animationDuration = (0.8 + Math.random() * 1) + "s";
    overlay.appendChild(el);
  }
  setTimeout(() => { overlay.style.display = "none"; overlay.innerHTML = ""; }, 2500);
}

document.getElementById("btnSfida").addEventListener("click", genera);
document.addEventListener("DOMContentLoaded", genera);
</script>
</body>
</html>