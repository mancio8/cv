<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>🍺 Beer Pong</title>

<style>
  :root {
    --bg: #0d0d0f;
    --surface: #18181c;
    --surface2: #222228;
    --border: #2e2e38;
    --text: #f0eee8;
    --muted: #6b6b7a;
    --bevi:    #22c55e;
    --penalita:#ef4444;
    --sfida:   #f59e0b;
    --social:  #3b82f6;
    --raro:    #a855f7;
    --bevi-bg:    #052e16;
    --penalita-bg:#450a0a;
    --sfida-bg:   #451a03;
    --social-bg:  #0c1a3a;
    --raro-bg:    #2e1065;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  /* Font stack senza Google Fonts (funziona offline/SES) */
  @font-face {
    font-family: 'DisplayFont';
    src: local('Impact'), local('Anton'), local('Arial Black');
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow-x: hidden;
  }

  /* Grana noise di sfondo */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  /* ---- HEADER ---- */
  header {
    width: 100%;
    max-width: 480px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px 0;
    position: relative;
    z-index: 1;
  }

  .logo {
    font-family: Impact, 'Arial Black', sans-serif;
    font-size: 2rem;
    letter-spacing: 2px;
    color: var(--text);
  }

  #countBadge {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 4px 12px;
    letter-spacing: 1px;
  }

  /* ---- CARD ---- */
  .card-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
    gap: 24px;
    width: 100%;
    max-width: 480px;
    position: relative;
    z-index: 1;
  }

  .card {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    min-height: 240px;
    justify-content: center;
    transition: border-color 0.3s, background 0.3s;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, var(--accent-glow, transparent) 0%, transparent 70%);
    pointer-events: none;
    transition: background 0.4s;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 999px;
    border: 1px solid currentColor;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.3s, transform 0.3s;
  }

  .badge.visible {
    opacity: 1;
    transform: translateY(0);
  }

  #eventoText {
    font-family: Impact, 'Arial Black', sans-serif;
    font-size: clamp(1.8rem, 7vw, 2.8rem);
    line-height: 1.15;
    text-align: center;
    letter-spacing: 1px;
    color: var(--text);
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* categoria colori applicati alla card */
  .cat-bevi    { --accent: var(--bevi);    --accent-bg: var(--bevi-bg);    --accent-glow: rgba(34,197,94,0.08); }
  .cat-penalita{ --accent: var(--penalita);--accent-bg: var(--penalita-bg);--accent-glow: rgba(239,68,68,0.08); }
  .cat-sfida   { --accent: var(--sfida);   --accent-bg: var(--sfida-bg);   --accent-glow: rgba(245,158,11,0.08); }
  .cat-social  { --accent: var(--social);  --accent-bg: var(--social-bg);  --accent-glow: rgba(59,130,246,0.08); }
  .cat-raro    { --accent: var(--raro);    --accent-bg: var(--raro-bg);    --accent-glow: rgba(168,85,247,0.12); }

  .card.cat-bevi,
  .card.cat-penalita,
  .card.cat-sfida,
  .card.cat-social,
  .card.cat-raro {
    border-color: var(--accent);
    background: linear-gradient(135deg, var(--surface) 60%, var(--accent-bg) 100%);
  }

  .badge.cat-bevi     { color: var(--bevi);    background: var(--bevi-bg);    border-color: var(--bevi); }
  .badge.cat-penalita { color: var(--penalita);background: var(--penalita-bg);border-color: var(--penalita); }
  .badge.cat-sfida    { color: var(--sfida);   background: var(--sfida-bg);   border-color: var(--sfida); }
  .badge.cat-social   { color: var(--social);  background: var(--social-bg);  border-color: var(--social); }
  .badge.cat-raro     { color: var(--raro);    background: var(--raro-bg);    border-color: var(--raro); }

  /* shake animation on reveal */
  @keyframes pop {
    0%   { transform: scale(0.94); opacity: 0; }
    60%  { transform: scale(1.03); }
    100% { transform: scale(1);    opacity: 1; }
  }
  @keyframes shakeCard {
    0%,100% { transform: rotate(0deg); }
    20%  { transform: rotate(-1.5deg); }
    40%  { transform: rotate(1.5deg); }
    60%  { transform: rotate(-1deg); }
    80%  { transform: rotate(0.8deg); }
  }
  @keyframes rarePulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(168,85,247,0); }
    50%     { box-shadow: 0 0 40px 8px rgba(168,85,247,0.35); }
  }

  .card.animate-pop  { animation: pop 0.35s cubic-bezier(.22,1,.36,1) forwards; }
  .card.animate-shake{ animation: shakeCard 0.4s ease forwards; }
  .card.cat-raro     { animation: rarePulse 1.8s ease-in-out infinite; }

  /* ---- BOTTONE ---- */
  .btn-sfida {
    width: 100%;
    padding: 18px;
    background: var(--text);
    color: var(--bg);
    font-family: Impact, 'Arial Black', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 3px;
    border: none;
    border-radius: 16px;
    cursor: pointer;
    transition: transform 0.15s, opacity 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-sfida:active { transform: scale(0.97); opacity: 0.85; }
  .btn-sfida:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ---- SLOT ANIMATION TEXT ---- */
  .slot-char {
    display: inline-block;
    animation: slotFlip 0.06s ease;
  }
  @keyframes slotFlip {
    0%   { transform: translateY(-4px); opacity: 0; }
    100% { transform: translateY(0);    opacity: 1; }
  }

  /* ---- FOOTER ---- */
  footer {
    padding: 16px;
    text-align: center;
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }

  /* ---- RARO OVERLAY ---- */
  .raro-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 999;
    display: none;
  }
  .confetti-piece {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    animation: confettiFall 1.2s ease-in forwards;
  }
  @keyframes confettiFall {
    0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
  }
</style>
</head>
