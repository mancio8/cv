/* ── APP LOGIC (IIFE injected into overlay) ─────────── */
function dmAppScript(){
const STORE="dm_players_v3";
const EMOJIS=["🎯","🏹","🎳","⚡","🔥","💎","🦁","🐉","🦊","👑","🌟","💀","🎲","🍀","🦅","🤖","🎪","🏆","⚔️","🛡️","🌊","🎭","🦄","🔮"];
