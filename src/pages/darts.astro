---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="DartMaster Pro" description="Tracker partite di freccette — X01, Cricket, Shanghai e molto altro." sideBarActiveItemID="darts">

<style>
/* ── LANDING ───────────────────────────────────────── */
.dm-landing {
  font-family: 'DM Sans', sans-serif;
}
.dm-hero {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 1rem 0 2rem;
}
.dm-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #00e599;
  background: #00e59912;
  border: 1px solid #00e59930;
  border-radius: 99px;
  padding: 4px 12px;
  width: fit-content;
}
.dm-h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.8rem, 7vw, 4.5rem);
  letter-spacing: 4px;
  line-height: 1;
  color: #e2f0ff;
  margin: 0;
}
.dm-h1 span { color: #00e599; }
.dm-desc {
  font-size: 1rem;
  color: #7da8cc;
  max-width: 480px;
  line-height: 1.65;
}
.dm-launch-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #00e599;
  color: #030e07;
  border: none;
  border-radius: 10px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.1rem;
  letter-spacing: 2px;
  padding: 14px 28px;
  cursor: pointer;
  transition: all .15s;
  width: fit-content;
}
.dm-launch-btn:hover { filter: brightness(1.1); transform: translateY(-1px); }
.dm-launch-btn:active { transform: scale(.96); }
.dm-launch-icon {
  width: 20px; height: 20px;
  border: 2.5px solid #030e07;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.dm-launch-icon::after {
  content: '';
  width: 0; height: 0;
  border-style: solid;
  border-width: 5px 0 5px 9px;
  border-color: transparent transparent transparent #030e07;
  margin-left: 2px;
}

/* modes grid */
.dm-modes {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 10px;
  margin: 1rem 0;
}
.dm-mode-card {
  background: #0a1526;
  border: 1px solid #162540;
  border-radius: 12px;
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  transition: all .18s;
  cursor: default;
}
.dm-mode-card:hover {
  border-color: #00e59940;
  background: #0e1c32;
}
.dm-mode-ic { font-size: 1.4rem; line-height: 1; }
.dm-mode-nm {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1rem;
  letter-spacing: 1.5px;
  color: #e2f0ff;
  margin-top: 2px;
}
.dm-mode-ds { font-size: 0.68rem; color: #4d7a99; line-height: 1.35; }

/* stats bar */
.dm-statsbar {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  padding: 16px;
  background: #0a1526;
  border: 1px solid #162540;
  border-radius: 12px;
}
.dm-stat {
  flex: 1;
  min-width: 80px;
  text-align: center;
}
.dm-stat-v {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1.4rem;
  font-weight: 700;
  color: #00e599;
}
.dm-stat-l {
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #4d7a99;
  margin-top: 2px;
}

/* section title */
.dm-section-t {
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #3d6080;
  margin-bottom: 10px;
}

/* screenshot mockup */
.dm-mockup {
  background: #060c17;
  border: 1px solid #162540;
  border-radius: 14px;
  overflow: hidden;
  position: relative;
}
.dm-mockup-bar {
  background: #0a1526;
  border-bottom: 1px solid #162540;
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.dm-mockup-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.1rem;
  letter-spacing: 3px;
  color: #00e599;
}
.dm-mockup-logo em { color: #4d7a99; font-style: normal; }
.dm-mockup-body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.dm-score-big {
  font-family: 'JetBrains Mono', monospace;
  font-size: clamp(56px, 12vw, 88px);
  font-weight: 700;
  color: #00e599;
  line-height: 1;
  text-align: center;
}
.dm-score-sub {
  text-align: center;
  font-size: 0.58rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #3d6080;
}
.dm-keypad-prev {
  display: flex;
  grid-template-columns: repeat(3,1fr);
  gap: 6px;
  justify-content: center;
}
.dm-key {
  background: #0e1c32;
  border: 1px solid #162540;
  border-radius: 8px;
  padding: 10px 14px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 1rem;
  font-weight: 700;
  color: #e2f0ff;
  text-align: center;
  flex: 1;
}
.dm-key.green { background: #00e599; color: #030e07; flex: 2; }

/* overlay launcher */
#dm-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(3,7,15,.96);
  align-items: center;
  justify-content: center;
}
#dm-overlay.open { display: flex; }
#dm-app-frame {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  position: relative;
}
.dm-close-btn {
  position: absolute;
  top: 12px;
  left: 225px;
  z-index: 10001;
  background: #0e1c32;
  border: 1px solid #253c60;
  border-radius: 8px;
  color: #7da8cc;
  font-size: 1rem;
  padding: 6px 12px;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: all .14s;
  display: none;
}
.dm-close-btn:hover { border-color: #ff3d5a; color: #ff3d5a; }
</style>

<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<div class="dm-landing">

  <!-- HERO -->
  <div class="dm-hero">
    <div class="dm-eyebrow">🎯 Darts Tracker</div>
    <h1 class="dm-h1">DART<span>MASTER</span><br>PRO</h1>
    <p class="dm-desc">
      Traccia ogni partita in tempo reale — X01, Cricket, Shanghai, Halve-It e altro.
      Statistiche dettagliate, rivalità testa a testa e modalità allenamento solo.
    </p>
    <button class="dm-launch-btn" onclick="document.getElementById('dm-overlay').classList.add('open'); document.body.style.overflow='hidden'">
      <span class="dm-launch-icon"></span>
      LANCIA L'APP
    </button>
  </div>

  <!-- STATS DAL LOCALE STORAGE -->
  <div>
    <div class="dm-section-t">Il tuo profilo</div>
    <div class="dm-statsbar" id="dm-stats-bar">
      <div class="dm-stat"><div class="dm-stat-v" id="st-players">—</div><div class="dm-stat-l">Giocatori</div></div>
      <div class="dm-stat"><div class="dm-stat-v" id="st-games">—</div><div class="dm-stat-l">Partite totali</div></div>
      <div class="dm-stat"><div class="dm-stat-v" id="st-avg">—</div><div class="dm-stat-l">Avg PPR top</div></div>
      <div class="dm-stat"><div class="dm-stat-v" id="st-best">—</div><div class="dm-stat-l">Best solo</div></div>
    </div>
  </div>

  <!-- MODALITÀ -->
  <div>
    <div class="dm-section-t">Modalità di gioco</div>
    <div class="dm-modes">
      <div class="dm-mode-card"><div class="dm-mode-ic">🎯</div><div class="dm-mode-nm">X01</div><div class="dm-mode-ds">501/301 — raggiungi zero esatto</div></div>
      <div class="dm-mode-card"><div class="dm-mode-ic">🏏</div><div class="dm-mode-nm">Cricket</div><div class="dm-mode-ds">Chiudi 15–20 e Bull prima degli avversari</div></div>
      <div class="dm-mode-card"><div class="dm-mode-ic">🌆</div><div class="dm-mode-nm">Shanghai</div><div class="dm-mode-ds">7 turni. Shanghai = vittoria istantanea</div></div>
      <div class="dm-mode-card"><div class="dm-mode-ic">✂️</div><div class="dm-mode-nm">Halve-It</div><div class="dm-mode-ds">Manca il target? Punteggio dimezzato</div></div>
      <div class="dm-mode-card"><div class="dm-mode-ic">🎲</div><div class="dm-mode-nm">Bob's 27</div><div class="dm-mode-ds">Parti da 27. Doppi in ordine</div></div>
      <div class="dm-mode-card"><div class="dm-mode-ic">🕐</div><div class="dm-mode-nm">Around Clock</div><div class="dm-mode-ds">Colpisci 1→20 in sequenza</div></div>
      <div class="dm-mode-card" style="border-color:#38b6ff28;background:#38b6ff06"><div class="dm-mode-ic">⏱️</div><div class="dm-mode-nm" style="color:#38b6ff">Countdown</div><div class="dm-mode-ds">Solo: quante freccette per azzerare?</div></div>
      <div class="dm-mode-card" style="border-color:#38b6ff28;background:#38b6ff06"><div class="dm-mode-ic">📈</div><div class="dm-mode-nm" style="color:#38b6ff">Scoring</div><div class="dm-mode-ds">Solo: 10 turni, massimizza il punteggio</div></div>
    </div>
  </div>

  <!-- MOCKUP PREVIEW -->
  <div>
    <div class="dm-section-t">Anteprima</div>
    <div class="dm-mockup">
      <div class="dm-mockup-bar">
        <div class="dm-mockup-logo">🎯 DART<em>MASTER</em></div>
        <div style="margin-left:auto;display:flex;gap:6px">
          <span style="background:#00e59918;border:1px solid #00e59930;border-radius:99px;font-size:0.6rem;font-weight:700;letter-spacing:1px;color:#00e599;padding:3px 9px">LIVE</span>
        </div>
      </div>
      <div class="dm-mockup-body">
        <div style="display:flex;gap:6px">
          <div style="flex:1;background:#0e1c32;border:1px solid #162540;border-radius:10px;padding:8px 6px;text-align:center;border-bottom:2px solid #00e599">
            <div style="font-size:0.5rem;color:#4d7a99;text-transform:uppercase;letter-spacing:1px;margin-bottom:2px">🎯 Luca</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:1.3rem;font-weight:700;color:#00e599">247</div>
            <div style="font-size:0.5rem;color:#fbbf24">avg 61.2</div>
          </div>
          <div style="flex:1;background:#0e1c32;border:1px solid #162540;border-radius:10px;padding:8px 6px;text-align:center;opacity:.6">
            <div style="font-size:0.5rem;color:#4d7a99;text-transform:uppercase;letter-spacing:1px;margin-bottom:2px">🔥 Marco</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:1.3rem;font-weight:700;color:#38b6ff">312</div>
            <div style="font-size:0.5rem;color:#fbbf24">avg 54.8</div>
          </div>
          <div style="flex:1;background:#0e1c32;border:1px solid #162540;border-radius:10px;padding:8px 6px;text-align:center;opacity:.5">
            <div style="font-size:0.5rem;color:#4d7a99;text-transform:uppercase;letter-spacing:1px;margin-bottom:2px">💎 Sara</div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:1.3rem;font-weight:700;color:#a78bfa">388</div>
            <div style="font-size:0.5rem;color:#fbbf24">avg 48.1</div>
          </div>
        </div>
        <div style="text-align:center;padding:8px 0">
          <div class="dm-score-big">247</div>
          <div class="dm-score-sub">turno corrente · +60</div>
          <div style="margin-top:6px;padding:3px 12px;border-radius:99px;background:#fbbf2414;border:1px solid #fbbf2428;color:#fbbf24;font-size:0.72rem;font-family:'JetBrains Mono',monospace;display:inline-block">→ T19 D25</div>
        </div>
        <div style="display:flex;gap:5px">
          <div class="dm-key">1</div>
          <div class="dm-key">2</div>
          <div class="dm-key">3</div>
          <div class="dm-key" style="background:#38b6ff18;color:#38b6ff;border-color:#38b6ff28">×2</div>
        </div>
        <div style="display:flex;gap:5px">
          <div class="dm-key green">✓ CONFERMA</div>
          <div class="dm-key" style="color:#ff3d5a;border-color:#ff3d5a22">C</div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- FULL-SCREEN OVERLAY CON L'APP -->
<div id="dm-overlay">
  <button class="dm-close-btn"
    onclick="document.getElementById('dm-overlay').classList.remove('open'); document.body.style.overflow=''">
    ✕ CHIUDI
  </button>

  <div id="dm-app-frame" style="width:100%;height:100%;overflow:hidden"></div>
</div>


<script is:inline>
/* ── STATS DALLA LANDING ─────────────────────────────── */
(function(){
  try{
    const players = JSON.parse(localStorage.getItem('dm_players_v3')) || [];
    document.getElementById('st-players').textContent = players.length || '0';
    const totalGames = players.reduce((s,p)=>s+(p.games_played||0),0);
    document.getElementById('st-games').textContent = totalGames || '0';
    const topAvg = players.length ? Math.max(...players.map(p=>p.avg_ppr||0)).toFixed(1) : '—';
    document.getElementById('st-avg').textContent = topAvg;
    const bests = players.map(p=>p.solo_best).filter(Boolean);
    document.getElementById('st-best').textContent = bests.length ? Math.min(...bests)+'🎯' : '—';
  } catch(e){}
})();

/* ── LAZY-LOAD APP NELL'OVERLAY ──────────────────────── */
let appLoaded = false;
document.querySelector('.dm-launch-btn').addEventListener('click', () => {
  if(appLoaded) return;
  appLoaded = true;
  const frame = document.getElementById('dm-app-frame');

  const appStyles = `
    <style>
    #dma{--bg:#060c17;--s1:#0a1526;--s2:#0e1c32;--s3:#12243e;--b1:#162540;--b2:#1d3050;--b3:#253c60;--grn:#00e599;--grn-a:#00e59918;--grn-b:#00e59935;--red:#ff3d5a;--red-a:#ff3d5a14;--blu:#38b6ff;--blu-a:#38b6ff14;--gld:#fbbf24;--gld-a:#fbbf2414;--prp:#a78bfa;--tx:#e2f0ff;--tx2:#7da8cc;--tx3:#3d6080;--font-d:'Bebas Neue',sans-serif;--font-m:'JetBrains Mono',monospace;--font-u:'DM Sans',sans-serif;--r:10px;--r2:14px;--r3:20px}
    #dma,#dma *{box-sizing:border-box!important;-webkit-tap-highlight-color:transparent!important;margin:0;padding:0}
    #dma{position:absolute;inset:0;z-index:1;background:var(--bg);color:var(--tx);font-family:var(--font-u);display:flex;flex-direction:column;overflow:hidden}
    #dma input,#dma select{all:unset;display:block;padding:11px 14px!important;border-radius:var(--r)!important;border:1px solid var(--b2)!important;background:var(--s1)!important;color:var(--tx)!important;font-size:14px!important;font-family:var(--font-u)!important;width:100%!important;transition:all .2s}
    #dma input:focus,#dma select:focus{outline:none!important;border-color:var(--grn)!important;box-shadow:0 0 0 3px var(--grn-b)!important}
    #dma select{cursor:pointer}
    #dma button{all:unset;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:6px}
    #dma .sc{display:none!important;width:100%;height:100%;overflow:hidden;flex-direction:column}
    #dma .sc.on{display:flex!important}
    #dma .si{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px}
    #dma .si::-webkit-scrollbar{width:3px}
    #dma .si::-webkit-scrollbar-thumb{background:var(--b2);border-radius:2px}
    #dma .tb{display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--s1);border-bottom:1px solid var(--b1);flex-shrink:0}
    #dma .tb-logo{font-family:var(--font-d);font-size:1.5rem;letter-spacing:3px;color:var(--grn);flex:1}
    #dma .tb-logo em{color:var(--tx2);font-style:normal}
    #dma .tb-title{font-family:var(--font-d);font-size:1.2rem;letter-spacing:2px;color:var(--grn);flex:1}
    #dma .db{padding:10px 18px;border-radius:var(--r);font-family:var(--font-d);font-size:.9rem;letter-spacing:1.5px;transition:all .14s;white-space:nowrap;border:1px solid transparent}
    #dma .db:active{transform:scale(.94)!important}
    #dma .db-p{background:var(--grn)!important;color:#030e07!important;border-color:var(--grn)!important}
    #dma .db-p:hover{filter:brightness(1.1)}
    #dma .db-g{background:transparent!important;color:var(--tx2)!important;border:1px solid var(--b2)!important;font-family:var(--font-u)!important;font-size:.82rem!important;letter-spacing:.3px!important}
    #dma .db-g:hover{border-color:var(--grn)!important;color:var(--grn)!important}
    #dma .db-d{background:var(--red-a)!important;color:var(--red)!important;border:1px solid #ff3d5a28!important;font-family:var(--font-u)!important;font-size:.82rem!important}
    #dma .db-i{background:var(--s2)!important;border:1px solid var(--b2)!important;color:var(--tx2)!important;padding:8px 12px!important;border-radius:var(--r)!important;font-size:1rem!important;transition:all .14s}
    #dma .db-i:hover{border-color:var(--grn)!important;color:var(--grn)!important}
    #dma .lbl{font-size:.58rem!important;font-weight:700!important;text-transform:uppercase;letter-spacing:2px;color:var(--tx3)}
    #dma .chip{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:99px;background:var(--s2);border:1px solid var(--b2);font-size:.8rem}
    #dma .chip-x{cursor:pointer;color:var(--tx3);font-size:.68rem;margin-left:2px}
    #dma .chip-x:hover{color:var(--red)}
    #dma .badge{display:inline-flex;align-items:center;padding:2px 9px;border-radius:99px;font-size:.62rem;font-weight:700;letter-spacing:.4px}
    #dma .badge-g{background:var(--grn-a);color:var(--grn);border:1px solid var(--grn-b)}
    #dma .badge-gld{background:var(--gld-a);color:var(--gld);border:1px solid #fbbf2430}
    #dma .badge-b{background:var(--blu-a);color:var(--blu);border:1px solid #38b6ff30}
    #dma .card{background:var(--s2);border:1px solid var(--b1);border-radius:var(--r2);overflow:hidden}
    #dma .card-h{padding:9px 13px;background:var(--s1);border-bottom:1px solid var(--b1);display:flex;align-items:center;gap:8px}
    #dma .card-b{padding:12px 13px;display:flex;flex-direction:column;gap:10px}
    #dma-toast{position:fixed;top:14px;left:50%;transform:translateX(-50%) translateY(-8px);padding:8px 18px;border-radius:var(--r);font-size:.85rem;font-weight:600;z-index:10000;opacity:0;pointer-events:none;transition:opacity .18s,transform .18s;background:var(--s3);border:1px solid var(--b2);color:var(--tx);font-family:var(--font-u);white-space:nowrap}
    #dma-toast.on{opacity:1!important;transform:translateX(-50%) translateY(0)!important}
    #dma-toast.bust{border-color:var(--red)!important;color:var(--red)!important;background:#140a10!important}
    #dma-toast.win{border-color:var(--gld)!important;color:var(--gld)!important;background:#14110a!important}
    #dma-toast.info{border-color:var(--grn)!important;color:var(--grn)!important}
    #dma-winner{display:none!important;position:fixed;inset:0;z-index:9999;background:rgba(3,7,15,.92);flex-direction:column;align-items:center;justify-content:center;gap:10px}
    #dma-winner.on{display:flex!important}
    #dma .wt{font-size:3.5rem;animation:dmPop .4s cubic-bezier(.36,.07,.19,.97) both}
    @keyframes dmPop{0%{transform:scale(0) rotate(-15deg)}70%{transform:scale(1.12) rotate(3deg)}100%{transform:scale(1)}}
    #dma .wtag{font-size:.6rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gld);background:var(--gld-a);border:1px solid #fbbf2430;border-radius:99px;padding:3px 12px}
    #dma .wname{font-family:var(--font-d);font-size:3rem;letter-spacing:5px;color:var(--tx);text-align:center;line-height:1}
    #dma .wsub{color:var(--tx2);font-size:.82rem;text-align:center}
    #dma .wact{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;justify-content:center}
    #dma .pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px}
    #dma .pc{background:var(--s2);border:1px solid var(--b1);border-radius:var(--r2);padding:14px 10px;text-align:center;cursor:pointer;transition:all .18s;position:relative;display:flex;flex-direction:column;align-items:center;gap:5px}
    #dma .pc:hover{border-color:var(--b2);transform:translateY(-2px)}
    #dma .pc.sel{background:var(--grn-a);box-shadow:0 0 0 1.5px var(--grn)}
    #dma .pc.sel::after{content:'✓';position:absolute;top:7px;right:9px;color:var(--grn);font-weight:700;font-size:.78rem}
    #dma .pc-av{font-size:2rem;line-height:1}
    #dma .pc-nm{font-weight:600;font-size:.82rem;color:var(--tx)}
    #dma .pc-st{font-size:.58rem;color:var(--tx2)}
    #dma .pc-add{background:var(--s1);border:1px dashed var(--b2);border-radius:var(--r2);padding:14px;text-align:center;cursor:pointer;transition:all .18s;color:var(--tx2);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;min-height:105px}
