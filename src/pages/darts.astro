const CRICKET_NUMS=[20,19,18,17,16,15,25];
const HALVEIT_T=["15","16","17","18","19","20","Bull","D Any","T Any","B+20"];
const CHECKOUTS={170:"T20 T20 Bull",167:"T20 T19 Bull",164:"T20 T18 Bull",161:"T20 T17 Bull",160:"T20 T20 D20",158:"T20 T18 D16",157:"T20 T19 D10",100:"T20 D20",96:"T20 D18",80:"T20 D10",72:"T20 D6",60:"S20 D20",50:"Bull",40:"D20",38:"D19",36:"D18",32:"D16",24:"D12",20:"D10",16:"D8",8:"D4",4:"D2",2:"D1"};
const SOLO_MODES=["COUNTDOWN","SCORING"];
let players=[],selIds=[],G={};
let moEditId=null,moEmoji="🎯",moColor="#00e599";
let chosenMode="X01";
function load(){try{players=JSON.parse(localStorage.getItem(STORE))||[];}catch{players=[];}}
function save(){localStorage.setItem(STORE,JSON.stringify(players));}
window.dmShowScreen=function(id){document.querySelectorAll("#dma .sc").forEach(s=>s.classList.remove("on"));document.getElementById(id).classList.add("on");};
window.dmHome=function(){document.getElementById("dma-winner").classList.remove("on");load();renderPlayers();dmShowScreen("sc-players");};
window.dmGoSetup=function(){renderSetup();dmShowScreen("sc-setup");};
window.dmStartSolo=function(){if(selIds.length===0){if(players.length===0){showToast("Crea prima un giocatore","bust");return;}selIds=[players[0].id];}else if(selIds.length>1){selIds=[selIds[0]];}chosenMode="X01";renderSetup();dmShowScreen("sc-setup");};
function renderPlayers(){const g=document.getElementById("pg");g.innerHTML="";players.forEach(p=>{const sel=selIds.includes(p.id);const d=document.createElement("div");d.className="pc"+(sel?" sel":"");if(sel)d.style.boxShadow=`0 0 0 1.5px ${p.color}`;d.innerHTML=`<div class="pc-av">${p.avatar}</div><div class="pc-nm">${p.name}</div><div class="pc-st">${p.games_played||0} partite · ${p.games_won||0} vittorie</div><div class="pc-st" style="color:var(--gld)">avg ${p.avg_ppr||0} PPR</div>`;d.onclick=()=>toggleSel(p.id);let lt;d.addEventListener("touchstart",()=>{lt=setTimeout(()=>openEdit(p.id),600);});d.addEventListener("touchend",()=>clearTimeout(lt));d.addEventListener("contextmenu",e=>{e.preventDefault();openEdit(p.id);});g.appendChild(d);});const add=document.createElement("div");add.className="pc-add";add.innerHTML=`<div class="pc-plus">＋</div><div style="font-size:.72rem;font-weight:600">Nuovo Giocatore</div>`;add.onclick=openNew;g.appendChild(add);const isSolo=selIds.length===1;const isMulti=selIds.length>=2;const pb=document.getElementById("play-btn");pb.style.display=(isSolo||isMulti)?"":"none";pb.textContent=isSolo?"▶ SOLO":"▶ GIOCA";renderRivalry();}
function toggleSel(id){const i=selIds.indexOf(id);if(i===-1)selIds.push(id);else selIds.splice(i,1);renderPlayers();}
function renderRivalry(){const z=document.getElementById("rv-zone");if(selIds.length!==2){z.style.display="none";return;}const a=players.find(p=>p.id===selIds[0]),b=players.find(p=>p.id===selIds[1]);if(!a||!b){z.style.display="none";return;}const key=`dm_h2h_${Math.min(a.id,b.id)}_${Math.max(a.id,b.id)}`;let h;try{h=JSON.parse(localStorage.getItem(key));}catch{}if(!h||h.games===0){z.style.display="none";return;}const aw=a.id<b.id?h.p1wins:h.p2wins,bw=a.id<b.id?h.p2wins:h.p1wins;z.style.display="";z.innerHTML=`<div class="rv"><div style="font-size:1.2rem">⚔️</div><div style="flex:1"><div style="font-size:.6rem;color:var(--tx2);margin-bottom:2px;text-transform:uppercase;letter-spacing:1px">Rivalità · ${h.games} partite</div><div style="font-weight:600;font-size:.85rem">${a.avatar} ${a.name} <span class="rv-sc">${aw} — ${bw}</span> ${b.name} ${b.avatar}</div></div></div>`;}
function updateH2H(wi){if(G.players.length<2)return;for(let i=0;i<G.players.length;i++){for(let j=i+1;j<G.players.length;j++){const pA=G.players[i],pB=G.players[j];const key=`dm_h2h_${Math.min(pA.id,pB.id)}_${Math.max(pA.id,pB.id)}`;let h;try{h=JSON.parse(localStorage.getItem(key));}catch{}h=h||{games:0,p1wins:0,p2wins:0};h.games++;const wid=G.players[wi]?.id;if(wid===Math.min(pA.id,pB.id))h.p1wins++;else if(wid===Math.max(pA.id,pB.id))h.p2wins++;localStorage.setItem(key,JSON.stringify(h));}}}
function openNew(){moEditId=null;moEmoji="🎯";moColor="#00e599";document.getElementById("mo-name").value="";document.getElementById("mo-title").textContent="NUOVO GIOCATORE";document.getElementById("mo-del").style.display="none";renderModal();document.getElementById("dma-modal").classList.add("on");}
function openEdit(id){const p=players.find(x=>x.id===id);if(!p)return;moEditId=id;moEmoji=p.avatar;moColor=p.color;document.getElementById("mo-name").value=p.name;document.getElementById("mo-title").textContent="MODIFICA";document.getElementById("mo-del").style.display="";renderModal();document.getElementById("dma-modal").classList.add("on");}
function renderModal(){document.getElementById("mo-emojis").innerHTML=EMOJIS.map(e=>`<div class="eo${e===moEmoji?" on":""}" onclick="dmPickEmoji('${e}')">${e}</div>`).join("");document.getElementById("mo-colors").innerHTML=COLORS.map(c=>`<div class="dm-co co${c===moColor?" on":""}" style="background:${c}" onclick="dmPickColor('${c}')"></div>`).join("");}
window.dmPickEmoji=function(e){moEmoji=e;renderModal();};
window.dmPickColor=function(c){moColor=c;renderModal();};
window.dmSavePlayer=function(){const name=document.getElementById("mo-name").value.trim();if(!name){showToast("Inserisci un nome","bust");return;}if(moEditId){const p=players.find(x=>x.id===moEditId);if(p){p.name=name;p.avatar=moEmoji;p.color=moColor;}}else{players.push({id:Date.now(),name,avatar:moEmoji,color:moColor,games_played:0,games_won:0,avg_ppr:0,best_leg:null,solo_best:null});}save();dmCloseModal();renderPlayers();};
window.dmDeletePlayer=function(){if(!moEditId)return;players=players.filter(p=>p.id!==moEditId);selIds=selIds.filter(id=>id!==moEditId);save();dmCloseModal();renderPlayers();};
window.dmCloseModal=function(){document.getElementById("dma-modal").classList.remove("on");};
function renderSetup(){const isSolo=selIds.length===1;document.querySelectorAll("#dma .mc.solo-only").forEach(el=>{el.style.display=isSolo?"":"none";});document.getElementById("sp-row").innerHTML=selIds.map(id=>{const p=players.find(x=>x.id===id);return`<div class="chip" style="border-color:${p.color}40"><span style="color:${p.color}">${p.avatar}</span><span>${p.name}</span><span class="chip-x" onclick="dmRemSel(${id})">✕</span></div>`;}).join("");if(!isSolo&&SOLO_MODES.includes(chosenMode)){chosenMode="X01";document.querySelectorAll("#dma .mc").forEach(c=>c.classList.remove("on"));document.querySelector("#dma .mc[data-mode='X01']").classList.add("on");}}
window.dmRemSel=function(id){selIds=selIds.filter(x=>x!==id);renderSetup();if(selIds.length===0){dmShowScreen("sc-players");renderPlayers();}};
window.dmSelMode=function(el){document.querySelectorAll("#dma .mc").forEach(c=>c.classList.remove("on"));el.classList.add("on");chosenMode=el.dataset.mode;document.getElementById("x01-opts").style.display=(chosenMode==="X01"||chosenMode==="BOBS27"||chosenMode==="COUNTDOWN")?"":"none";};
window.dmInitGame=function(){const score=parseInt(document.getElementById("start-score").value)||501;const outRule=document.getElementById("out-rule").value;const isSolo=selIds.length===1;G={mode:chosenMode,outRule,startScore:score,isSolo,players:selIds.map(id=>{const r=players.find(p=>p.id===id);return{id:r.id,name:r.name,avatar:r.avatar,color:r.color,score:(chosenMode==="X01"||chosenMode==="COUNTDOWN")?score:(chosenMode==="BOBS27"?27:0),totalScored:0,dartsThrown:0,highTurn:0,bustsCount:0,checkoutAttempts:0,checkoutHits:0,cricket:{20:0,19:0,18:0,17:0,16:0,15:0,25:0},atcTarget:1,shanghaiScore:0,halveScore:0,scoringScore:0,scoringTurns:0,_halveHit:false,_shanghaiHits:{},turnHistory:[]};}),current:0,buffer:"",mod:1,darts:0,turnScore:0,history:[],turnLog:[],shanghaiRound:1,halveRound:0,scoringRound:0};dmShowScreen("sc-game");updateUI();};
window.dmPress=function(n){if(n===25)G.buffer="25";else if(G.buffer.length<2)G.buffer+=n;updatePreview();};
window.dmMod=function(m){G.mod=(G.mod===m)?1:m;updatePreview();};
window.dmClear=function(){G.buffer="";G.mod=1;updatePreview();};
function updatePreview(){const val=G.buffer?parseInt(G.buffer):null,eff=val!==null?val*G.mod:null;document.getElementById("kpn").textContent=G.buffer||"—";document.getElementById("kpm").textContent=G.mod>1?`×${G.mod} =`:"mod";document.getElementById("kpe").textContent=eff!==null?(G.mod>1?`${eff}`:eff):"—";document.getElementById("km2").className="k k-mod"+(G.mod===2?" on":"");document.getElementById("km3").className="k k-mod"+(G.mod===3?" on":"");}
function saveState(){G.history.push(JSON.stringify({players:JSON.parse(JSON.stringify(G.players)),current:G.current,darts:G.darts,turnScore:G.turnScore,turnLog:JSON.parse(JSON.stringify(G.turnLog)),shanghaiRound:G.shanghaiRound,halveRound:G.halveRound,scoringRound:G.scoringRound}));if(G.history.length>50)G.history.shift();}
window.dmUndo=function(){if(!G.history.length)return;Object.assign(G,JSON.parse(G.history.pop()));dmClear();updateUI();};
window.dmConfirm=function(){if(G.buffer==="")return;saveState();const val=parseInt(G.buffer)||0,pts=val*G.mod,p=G.players[G.current];if(G.mode==="X01"||G.mode==="COUNTDOWN")hX01(p,val,pts);else if(G.mode==="CRICKET")hCricket(p,val);else if(G.mode==="ATC")hATC(p,val);else if(G.mode==="SHANGHAI")hShanghai(p,val);else if(G.mode==="HALVEIT")hHalveIt(p,val);else if(G.mode==="BOBS27")hBobs(p,val);else if(G.mode==="SCORING")hScoring(p,val,pts);p.dartsThrown++;G.darts++;dmClear();if(G.darts>=3){G.turnLog.push({playerIdx:G.current,score:G.turnScore,bust:false,darts:3});p.turnHistory.push(G.turnScore);setTimeout(dmSkip,350);}updateUI();};
function hX01(p,val,pts){const rem=p.score-pts;if(p.score<=170)p.checkoutAttempts++;let bust=false;if(G.outRule==="DOUBLE"){if(rem<0||rem===1||(rem===0&&G.mod!==2))bust=true;}else{if(rem<0)bust=true;}if(bust){p.bustsCount++;G.turnLog.push({playerIdx:G.current,score:G.turnScore,bust:true,darts:G.darts+1});p.turnHistory.push(0);showToast("💥 BUST!","bust");G.turnScore=0;G.darts=3;return;}p.score=rem;G.turnScore+=pts;p.totalScored+=pts;p.highTurn=Math.max(p.highTurn,G.turnScore);if(rem===0){p.checkoutHits++;G.turnLog.push({playerIdx:G.current,score:G.turnScore,bust:false,darts:G.darts+1});p.turnHistory.push(G.turnScore);dmWin(G.current);}}
function hCricket(p,val){if(!CRICKET_NUMS.includes(val))return;const others=G.players.filter((_,i)=>i!==G.current);for(let i=0;i<G.mod;i++){if(p.cricket[val]<3){p.cricket[val]++;}else{const ac=others.every(o=>o.cricket[val]>=3);if(!ac){p.score+=val;p.totalScored+=val;}}}G.turnScore+=val;if(CRICKET_NUMS.every(n=>p.cricket[n]>=3))dmWin(G.current);}
function hATC(p,val){if(val===p.atcTarget){p.atcTarget++;p.totalScored++;G.turnScore++;}if(p.atcTarget>20)dmWin(G.current);}
function hShanghai(p,val){if(val!==G.shanghaiRound)return;const pts=val*G.mod;p.shanghaiScore+=pts;p.totalScored+=pts;G.turnScore+=pts;p._shanghaiHits[G.mod]=true;if(p._shanghaiHits[1]&&p._shanghaiHits[2]&&p._shanghaiHits[3]){showToast("🌆 SHANGHAI!","win");dmWin(G.current);}}
function hHalveIt(p,val){const t=HALVEIT_T[G.halveRound];let hit=false;if(t==="Bull"&&val===25)hit=true;else if(t==="D Any"&&G.mod===2&&val>0)hit=true;else if(t==="T Any"&&G.mod===3&&val>0)hit=true;else if(t==="B+20"&&(val===25||val===20))hit=true;else if(parseInt(t)===val&&G.mod===1)hit=true;if(hit){const pts=val*G.mod;p.halveScore+=pts;p.totalScored+=pts;G.turnScore+=pts;p._halveHit=true;}}
function hBobs(p,val){const tgt=Math.ceil((p.dartsThrown+1)/3);if(val===tgt&&G.mod===2){const pts=tgt*2;p.score+=pts;p.totalScored+=pts;G.turnScore+=pts;}}
function hScoring(p,val,pts){p.scoringScore+=pts;p.totalScored+=pts;G.turnScore+=pts;p.highTurn=Math.max(p.highTurn,G.turnScore);}
window.dmSkip=function(){const p=G.players[G.current];const next=(G.current+1)%G.players.length;if(G.mode==="SCORING"){p.scoringTurns++;if(p.scoringTurns>=10&&G.isSolo){dmWin(G.current);return;}G.scoringRound++;if(G.scoringRound>=10&&!G.isSolo){const w=G.players.reduce((a,b)=>a.scoringScore>b.scoringScore?a:b);dmWin(G.players.indexOf(w));return;}}if(G.mode==="HALVEIT"){if(!p._halveHit&&p.halveScore>0){p.halveScore=Math.floor(p.halveScore/2);showToast(`✂️ ${p.name}: dimezzato!`,"bust");}p._halveHit=false;if(next===0){G.halveRound++;if(G.halveRound>=HALVEIT_T.length){const w=G.players.reduce((a,b)=>a.halveScore>b.halveScore?a:b);dmWin(G.players.indexOf(w));return;}}}if(G.mode==="SHANGHAI"){p._shanghaiHits={};if(next===0){G.shanghaiRound++;if(G.shanghaiRound>7){const w=G.players.reduce((a,b)=>a.shanghaiScore>b.shanghaiScore?a:b);dmWin(G.players.indexOf(w));return;}}}if(G.mode==="BOBS27"){const tgt=Math.ceil(p.dartsThrown/3);if(G.turnScore===0&&tgt>=1){p.score-=tgt*2;showToast(`😬 ${p.name}: -${tgt*2}`,"bust");}}G.darts=0;G.turnScore=0;G.current=next;dmClear();updateUI();};
function dmWin(idx){const p=G.players[idx];if(!G.isSolo)updateH2H(idx);players.forEach(ap=>{const gp=G.players.find(x=>x.id===ap.id);if(!gp)return;ap.games_played=(ap.games_played||0)+1;if(gp.id===p.id)ap.games_won=(ap.games_won||0)+1;const rounds=Math.max(1,Math.ceil(gp.dartsThrown/3));const ppr=parseFloat((gp.totalScored/rounds).toFixed(1));ap.avg_ppr=ap.games_played===1?ppr:parseFloat(((ap.avg_ppr*(ap.games_played-1)+ppr)/ap.games_played).toFixed(1));if(G.isSolo&&(G.mode==="X01"||G.mode==="COUNTDOWN")){if(!ap.solo_best||gp.dartsThrown<ap.solo_best)ap.solo_best=gp.dartsThrown;}});save();let sub=`vittoria in ${p.dartsThrown} freccette`;const rounds=Math.max(1,Math.ceil(p.dartsThrown/3));sub+=` · avg ${(p.totalScored/rounds).toFixed(1)} PPR`;if(G.isSolo&&G.mode==="SCORING")sub=`${p.scoringScore} punti in 10 turni`;document.getElementById("w-name").textContent=p.name.toUpperCase();document.getElementById("w-sub").textContent=sub;document.getElementById("dma-winner").classList.add("on");}
function updateUI(){const p=G.players[G.current];if(!p)return;document.getElementById("ptabs").innerHTML=G.players.map((pl,i)=>{const rounds=Math.max(1,Math.ceil(pl.dartsThrown/3));const avg=(pl.totalScored/rounds).toFixed(1);let ds;if(G.mode==="ATC")ds=pl.atcTarget;else if(G.mode==="SHANGHAI")ds=pl.shanghaiScore;else if(G.mode==="HALVEIT")ds=pl.halveScore;else if(G.mode==="SCORING")ds=pl.scoringScore;else ds=pl.score;return`<div class="ptab${i===G.current?" on":""}"><div class="ptab-nm">${pl.avatar} ${pl.name}</div><div class="ptab-sc" style="color:${pl.color}">${ds}</div><div class="ptab-av">avg ${avg}</div></div>`;}).join("");const dots=document.getElementById("dots").children;for(let i=0;i<3;i++){const f=i<(3-G.darts);dots[i].className="dot"+(f?" on":"");dots[i].style.background=f?p.color:"transparent";dots[i].style.borderColor=f?p.color:"var(--b2)";dots[i].style.boxShadow=f?`0 0 7px ${p.color}50`:"none";}const spw=document.getElementById("solo-panel-wrap");if(G.isSolo&&p.dartsThrown>0){const rounds2=Math.max(1,Math.ceil(p.dartsThrown/3));const avg2=(p.totalScored/rounds2).toFixed(1);const dart100=p.turnHistory.filter(t=>t>=100).length;let extra="";if(G.mode==="SCORING"){extra=`<div class="solo-stat"><div class="solo-stat-v" style="color:var(--grn)">${10-p.scoringTurns}</div><div class="solo-stat-l">Turni rimasti</div></div>`;}else if(G.mode==="COUNTDOWN"||G.mode==="X01"){extra=`<div class="solo-stat"><div class="solo-stat-v" style="color:var(--blu)">${p.dartsThrown}</div><div class="solo-stat-l">Freccette</div></div>`;}spw.innerHTML=`<div class="solo-panel"><div class="lbl" style="margin-bottom:7px">⚡ Live Stats</div><div class="solo-stat-row"><div class="solo-stat"><div class="solo-stat-v" style="color:var(--grn)">${avg2}</div><div class="solo-stat-l">Avg PPR</div></div><div class="solo-stat"><div class="solo-stat-v" style="color:var(--gld)">${p.highTurn}</div><div class="solo-stat-l">High</div></div><div class="solo-stat"><div class="solo-stat-v" style="color:var(--prp)">${dart100}</div><div class="solo-stat-l">100+</div></div>${extra}</div></div>`;}else{spw.innerHTML="";}const dc=document.getElementById("dc");if(G.mode==="CRICKET"){const sym=n=>["","╱","✕","⊗"][Math.min(n,3)];const hcols=G.players.map(pl=>`<th style="text-align:center;padding:7px 7px;color:${pl.color};font-size:.7rem;font-weight:700;white-space:nowrap;letter-spacing:.4px">${pl.avatar} ${pl.name}</th>`).join("");const rows=CRICKET_NUMS.map(n=>{const ac=G.players.every(pl=>pl.cricket[n]>=3);const cells=G.players.map(pl=>`<td style="text-align:center;padding:6px 4px;font-size:1rem;color:${pl.color};opacity:${ac?0.22:1}">${sym(pl.cricket[n])}</td>`).join("");return`<tr style="border-bottom:1px solid var(--b1)">${cells}<td style="text-align:center;padding:6px 12px;font-family:var(--font-d);font-size:1rem;font-weight:700;color:${ac?"var(--tx3)":"var(--tx)"};border-left:1px solid var(--b2);min-width:50px">${n===25?"Bull":n}</td></tr>`;}).join("");dc.innerHTML=`<div style="width:94%;max-width:500px;overflow-x:auto"><table style="width:100%;border-collapse:collapse"><thead><tr style="border-bottom:1px solid var(--b2)">${hcols}<th style="border-left:1px solid var(--b2);min-width:50px"></th></tr></thead><tbody>${rows}</tbody></table></div>`;}else if(G.mode==="ATC"){dc.innerHTML=`<div class="tg"><div class="tg-l">Target</div><div class="tg-n" style="color:${p.color}">${p.atcTarget}</div><div class="tg-s">colpisci per avanzare</div></div>`;}else if(G.mode==="SHANGHAI"){dc.innerHTML=`<div class="tg"><div class="tg-l">Round ${G.shanghaiRound}/7 — colpisci il</div><div class="tg-n" style="color:${p.color}">${G.shanghaiRound}</div><div class="tg-s">S+D+T stesso turno = Shanghai!</div><div style="margin-top:8px;font-family:var(--font-m);font-size:1rem;color:var(--blu)">+${G.turnScore} questo turno</div></div>`;}else if(G.mode==="HALVEIT"){dc.innerHTML=`<div class="tg"><div class="tg-l">Round ${G.halveRound+1} — target</div><div class="tg-n" style="color:${p.color};font-size:3.2rem">${HALVEIT_T[G.halveRound]}</div><div class="tg-s">manca → punteggio dimezzato</div><div style="margin-top:8px;font-family:var(--font-m);font-size:1.4rem;color:${p.color}">${p.halveScore} pts</div></div>`;}else if(G.mode==="BOBS27"){const bt=Math.ceil((p.dartsThrown+1)/3);dc.innerHTML=`<div class="tg"><div class="tg-l">Doppio da colpire</div><div class="tg-n" style="color:${p.color}">D${bt}</div><div class="tg-s">sbaglia: -${bt*2} pts</div><div class="big" style="font-size:clamp(46px,7vw,88px);margin-top:6px;color:${p.score<0?"var(--red)":p.color}">${p.score}</div></div>`;}else if(G.mode==="SCORING"){const turns_left=10-p.scoringTurns;dc.innerHTML=`<div class="tg"><div class="tg-l">Turno ${p.scoringTurns+1}/10 — massimizza</div><div class="big" style="font-size:clamp(60px,10vw,110px);color:${p.color}">${p.scoringScore}</div><div class="tg-s">${turns_left} turni rimasti · +${G.turnScore} ora</div></div>`;}else{dc.innerHTML=`<div class="big" style="color:${p.color}">${p.score}</div><div class="tl">turno corrente</div><div class="tp">${G.turnScore>0?"+"+G.turnScore:"—"}</div>`;}const hint=(G.mode==="X01"||G.mode==="COUNTDOWN")&&G.outRule==="DOUBLE"?getHint(p.score):"";const he=document.getElementById("co-hint");he.textContent=hint?"→ "+hint:"";he.style.opacity=hint?1:0;updatePreview();}
function getHint(s){if(s>170||s<2)return"";if(CHECKOUTS[s])return CHECKOUTS[s];if(s<=40&&s%2===0)return"D"+(s/2);return"";}
window.dmShowStats=function(){document.getElementById("dma-winner").classList.remove("on");buildStats();dmShowScreen("sc-stats");};
function buildStats(){const body=document.getElementById("stats-body");const isSolo=G.isSolo;const p=G.players[0];if(isSolo){const rounds=Math.max(1,Math.ceil(p.dartsThrown/3));const avg=(p.totalScored/rounds).toFixed(1);const dart100=p.turnHistory.filter(t=>t>=100).length;const dart0=p.turnHistory.filter(t=>t===0).length;const maxH=Math.max(...p.turnHistory,1);const bars=p.turnHistory.map(t=>{return`<div class="sh-row"><div class="sh-n">#${p.turnHistory.indexOf(t)+1}</div><div class="sh-s" style="color:${t>=100?"var(--grn)":t===0?"var(--red)":"var(--tx)"}">${t}</div><div class="sh-bar"><div class="sh-bf" style="width:${Math.round((t/maxH)*100)}%;background:${t>=100?"var(--grn)":t===0?"var(--red)":"var(--blu)"}"></div></div>${t>=100?'<span class="badge badge-g" style="font-size:.5rem">100+</span>':t===0?'<span class="badge" style="background:var(--red-a);color:var(--red);border:1px solid #ff3d5a28;font-size:.5rem">BUST</span>':""}</div>`;}).join("");const ap=players.find(x=>x.id===p.id);const pb=ap?.solo_best;body.innerHTML=`<div style="display:flex;align-items:center;gap:10px;padding:6px 0 4px"><div style="font-size:2rem">${p.avatar}</div><div><div style="font-weight:700;font-size:1.1rem">${p.name}</div><div style="font-size:.7rem;color:var(--tx2)">${G.mode} · ${p.dartsThrown} freccette · ${rounds} turni</div></div>${G.mode==="SCORING"?`<span class="badge badge-g" style="margin-left:auto">${p.scoringScore} PTS</span>`:`<span class="badge badge-b" style="margin-left:auto">${p.dartsThrown} 🎯</span>`}</div><div class="sg"><div class="scard"><div class="scard-l">Media PPR</div><div class="scard-v" style="color:var(--grn)">${avg}</div><div class="scard-s">punti per turno</div></div><div class="scard"><div class="scard-l">Turno top</div><div class="scard-v" style="color:var(--gld)">${p.highTurn}</div><div class="scard-s">massimo in una mano</div></div><div class="scard"><div class="scard-l">Turni 100+</div><div class="scard-v" style="color:var(--prp)">${dart100}</div><div class="scard-s">su ${rounds} turni totali</div></div><div class="scard"><div class="scard-l">Bust / Zero</div><div class="scard-v" style="color:var(--red)">${dart0+p.bustsCount}</div><div class="scard-s">turni sprecati</div></div></div>${pb?`<div class="card"><div class="card-h"><div class="lbl">🏅 Record personale</div></div><div class="card-b" style="flex-direction:row;align-items:center;justify-content:space-between"><div style="font-size:.82rem;color:var(--tx2)">Miglior partita X01/Countdown</div><div style="font-family:var(--font-m);font-weight:700;color:var(--gld)">${pb} 🎯</div></div></div>`:""}<div class="card"><div class="card-h"><div class="lbl">📋 Storico turni</div></div><div class="card-b"><div class="solo-history">${bars||'<div style="color:var(--tx2);font-size:.8rem">Nessun turno completato</div>'}</div></div></div><button class="db db-g" style="width:100%;margin-top:2px" onclick="dmHome()">↩ TORNA AL MENU</button>`;return;}const sorted=[...G.players].sort((a,b)=>{if(G.mode==="X01"||G.mode==="BOBS27")return a.score-b.score;if(G.mode==="SHANGHAI")return b.shanghaiScore-a.shanghaiScore;if(G.mode==="HALVEIT")return b.halveScore-a.halveScore;if(G.mode==="SCORING")return b.scoringScore-a.scoringScore;return b.totalScored-a.totalScored;});let pod=`<div class="podium">`;sorted.slice(0,3).forEach((p2,i)=>{pod+=`<div class="pd-sl"><div class="pd-nm">${p2.avatar} ${p2.name}</div><div class="pd-bl ${["r1","r2","r3"][i]}"><div class="pd-rk">${["🥇","🥈","🥉"][i]}</div></div><div class="pd-sb">${p2.dartsThrown} 🎯</div></div>`;});pod+=`</div>`;const td=G.players.reduce((s,p2)=>s+p2.dartsThrown,0);const tb=G.players.reduce((s,p2)=>s+p2.bustsCount,0);const ht=G.turnLog.reduce((m,t)=>Math.max(m,t.score),0);const tt=G.turnLog.length;const glob=`<div><div class="lbl" style="margin-bottom:9px">Partita</div><div class="sg"><div class="scard"><div class="scard-l">Freccette totali</div><div class="scard-v">${td}</div><div class="scard-s">${tt} turni</div></div><div class="scard"><div class="scard-l">Bust totali</div><div class="scard-v" style="color:var(--red)">${tb}</div><div class="scard-s">${tt>0?((tb/tt)*100).toFixed(0):0}% turni</div></div><div class="scard"><div class="scard-l">Turno top</div><div class="scard-v" style="color:var(--gld)">${ht}</div><div class="scard-s">in una mano</div></div><div class="scard"><div class="scard-l">Modalità</div><div class="scard-v" style="font-size:.88rem">${G.mode}</div><div class="scard-s">${G.outRule||"—"}</div></div></div></div>`;const maxPPR=Math.max(...G.players.map(p2=>p2.totalScored/Math.max(1,Math.ceil(p2.dartsThrown/3))));let pl=`<div><div class="lbl" style="margin-bottom:9px">Giocatori</div>`;G.players.forEach((p2,idx)=>{const rounds2=Math.max(1,Math.ceil(p2.dartsThrown/3));const ppr=(p2.totalScored/rounds2).toFixed(1);const bw=Math.round((parseFloat(ppr)/Math.max(1,maxPPR))*100);const co=p2.checkoutAttempts>0?`${((p2.checkoutHits/p2.checkoutAttempts)*100).toFixed(0)}%`:"N/A";const mt=G.turnLog.filter(t=>t.playerIdx===idx);const mx=Math.max(...mt.map(t=>t.score),1);const brs=mt.slice(-20).map(t=>{const h=Math.max(3,Math.round((t.score/mx)*38));return`<div class="tcb${t.bust?" bust":t.score>=100?" high":""}" style="height:${h}px"></div>`;}).join("");pl+=`<div class="psb"><div class="psb-h"><div style="font-size:1.4rem">${p2.avatar}</div><div style="flex:1"><div style="font-weight:600;font-size:.85rem">${p2.name}</div><div style="font-size:.58rem;color:var(--tx2)">${p2.dartsThrown} freccette · ${rounds2} turni</div></div>${idx===0?`<span class="badge badge-gld">🏆 WINNER</span>`:""}</div><div class="psb-b"><div class="psb-r"><span class="psb-l">Media PPR</span><span class="psb-v" style="color:${p2.color}">${ppr}</span></div><div class="bar-t"><div class="bar-f" style="width:${bw}%;background:${p2.color}"></div></div><div class="psb-r"><span class="psb-l">Turno migliore</span><span class="psb-v" style="color:var(--gld)">${p2.highTurn}</span></div>${G.mode==="X01"?`<div class="psb-r"><span class="psb-l">Checkout %</span><span class="psb-v">${co}</span></div>`:""}<div class="psb-r"><span class="psb-l">Bust</span><span class="psb-v" style="color:var(--red)">${p2.bustsCount}</span></div>${mt.length>0?`<div><div class="lbl" style="margin-bottom:4px">Andamento</div><div class="tc">${brs}</div></div>`:""}</div></div>`;});pl+=`</div>`;body.innerHTML=pod+glob+pl+`<button class="db db-g" style="width:100%;margin-top:2px" onclick="dmHome()">↩ TORNA AL MENU</button>`;}
function showToast(msg,type){const t=document.getElementById("dma-toast");t.textContent=msg;t.className="on"+(type?" "+type:"");clearTimeout(t._t);t._t=setTimeout(()=>{t.className="";},2200);}
load();renderPlayers();
}
</script>

</BaseLayout>